---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GradientButton from '../../components/ui/GradientButton.svelte';

const features = [
  {
    title: 'Custom E-commerce Solutions',
    description: 'Tailored online stores built to your specific business needs',
    icon: 'ph ph-storefront ph-bold'
  },
  {
    title: 'Secure Payment Integration',
    description: 'Multiple payment gateways with robust security measures',
    icon: 'ph ph-credit-card ph-bold'
  },
  {
    title: 'Inventory Management',
    description: 'Real-time stock tracking and automated inventory updates',
    icon: 'ph ph-package ph-bold'
  },
  {
    title: 'Analytics & Reporting',
    description: 'Comprehensive insights into your store performance',
    icon: 'ph ph-chart-line ph-bold'
  }
];
---

<BaseLayout 
  title="E-commerce Solutions" 
  description="Custom e-commerce development solutions to help your business grow online"
>
  <div class="pt-32 pb-24 relative overflow-hidden section-bg">
    <!-- Spotlights -->
    <div class="spotlight spotlight-1"></div>
    <div class="spotlight spotlight-2"></div>
    <div class="spotlight spotlight-3"></div>

    <!-- Background Elements -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(79,70,229,0.05),transparent_50%)]"></div>
      <div class="code-grid"></div>
    </div>

    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <div class="preheading-code">services/ecommerce</div>
        <h1 class="heading-code">
          export class <span class="text-indigo-400">EcommerceSolutions</span>
        </h1>
        <p class="subheading-code">
          // Building powerful online stores that drive growth
        </p>
      </div>

      <!-- Features Grid -->
      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {features.map(feature => (
          <div class="glass-card p-6 rounded-xl hover:scale-105 transform transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="service-icon">
                <i class={`${feature.icon} text-2xl`}></i>
              </div>
              <div>
                <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
                <p class="text-blue-100/70">{feature.description}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA Section -->
      <div class="text-center mt-16">
        <GradientButton href="#contact" client:load>
          startEcommerce
          <i class="ph ph-shopping-cart-simple ml-2"></i>
        </GradientButton>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .glass-card {
    background: rgba(15, 15, 26, 0.8);
    border: 1px solid rgba(79, 70, 229, 0.2);
    backdrop-filter: blur(12px);
  }

  .service-icon {
    @apply flex items-center justify-center w-12 h-12 rounded-lg bg-indigo-500/20 text-indigo-400;
    transition: all 0.3s ease;
  }

  .code-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(to right, rgba(79, 70, 229, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(79, 70, 229, 0.05) 1px, transparent 1px);
    background-size: 24px 24px;
    mask-image: radial-gradient(circle at 50% 50%, black, transparent 70%);
  }
</style>
